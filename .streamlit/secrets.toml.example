# Copy to .streamlit/secrets.toml for local testing,
# OR paste into Streamlit Cloud → App settings → Secrets.
# NEVER commit the real secrets.toml — it is gitignored.

# Generate with: python setup_auth.py --hash-only
# (or any bcrypt tool — cost factor 12 recommended)
password_hash = "$2b$12$REPLACE_WITH_REAL_HASH"

# ── Notifications (optional — only needed if using Google Calendar / Gmail) ───
user_email    = "your.email@gmail.com"
calendar_id   = "primary"
timezone      = "America/Vancouver"
