# Copy to .streamlit/secrets.toml for local testing,
# OR paste into Streamlit Cloud → App settings → Secrets.
# NEVER commit the real secrets.toml — it is gitignored.

# Generate password hash with:
# python3 -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt(12)).decode())"
password_hash = "$2b$12$REPLACE_WITH_REAL_HASH"

[database]
# Postgres connection string from Supabase → Settings → Database → URI
url = "postgresql://postgres:YOUR_DB_PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres"
